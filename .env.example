# Frontend (Vite)
# Where the frontend sends API requests.
VITE_API_BASE_URL=http://localhost:4010/api

# Optional: set to true to run frontend with local mock data instead of backend API.
VITE_USE_MOCK_DATA=false

# Backend
# Port for Express server.
PORT=4010

# Optional host binding; use 127.0.0.1 for local-only.
HOST=127.0.0.1
