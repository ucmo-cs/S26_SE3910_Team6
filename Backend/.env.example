# Copy to Backend/.env (or project root .env) and add your keys.

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# Optional model override (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Resend API key — get one at https://resend.com/api-keys (no password)
RESEND_API_KEY=re_xxxxxxxxxxxx

# IMPORTANT: With the default "from" (onboarding@resend.dev), Resend only delivers
# to the email address on your Resend account. To send to any customer email you must:
# 1. Add and verify a domain at https://resend.com/domains
# 2. Set RESEND_FROM to an address at that domain, e.g.:
# RESEND_FROM=Appointments <appointments@yourdomain.com>
